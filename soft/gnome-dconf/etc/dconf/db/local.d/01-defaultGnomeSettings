[org/gnome/desktop/input-sources]
mru-sources=[('xkb', 'us'), ('xkb', 'ua')]
per-window=true
sources=[('xkb', 'us'), ('xkb', 'ua')]
xkb-options=['lv3:ralt_switch', 'ctrl:nocaps']

[org/gnome/desktop/interface]
cursor-theme='breeze_cursors'
document-font-name='Sans 12'
font-name='Sans 11'
monospace-font-name='Mono 11'


[org/gnome/desktop/peripherals/keyboard]
numlock-state=true

[org/gnome/desktop/peripherals/touchpad]
tap-to-click=true
two-finger-scrolling-enabled=true

[org/gnome/desktop/screensaver]
lock-delay=uint32 3600

[org/gnome/desktop/wm/preferences]
button-layout='close:'
titlebar-font='Sans Bold 11'

[org/gnome/epiphany]
default-search-engine='Google'
search-engine-providers=[{'url': <'https://www.google.com/search?q=%s'>, 'bang': <'!g'>, 'name': <'Google'>}]

[org/gnome/nautilus/preferences]
click-policy='single'

[org/gnome/settings-daemon/plugins/color]
night-light-enabled=true
night-light-temperature=uint32 4000

[org/gnome/settings-daemon/plugins/media-keys]
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/']
home=['<Super>e']
search=['<Super>r']

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0]
binding='<Super>Return'
command='kitty'
name='terminal'

[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-timeout=6000
sleep-inactive-ac-type='suspend'


[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'org.gnome.Calendar.desktop', 'org.gnome.Music.desktop', 'org.gnome.Software.desktop', 'org.gnome.Console.desktop']
welcome-dialog-last-shown-version='45.4'
